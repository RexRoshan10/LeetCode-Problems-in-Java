class Solution {
    public boolean canPartitionGrid(int[][] grid) {
        int m = grid.length;
        int n = grid[0].length;

        long[] ver = new long[n];
        long[] hor = new long[m];

        // Row sums
        for(int i = 0; i < m; i++) {
            for(int j = 0; j < n; j++) {
                hor[i] += grid[i][j];
            }
        }

        // Column sums
        for(int j = 0; j < n; j++) {
            for(int i = 0; i < m; i++) {
                ver[j] += grid[i][j];
            }
        }

        // Vertical partition
        long total = 0;
        for(long val : ver) total += val;

        long prefix = 0;
        for(int i = 0; i < n - 1; i++) {
            prefix += ver[i];
            if(prefix == total - prefix) return true;
        }

        // Horizontal partition
        total = 0;
        for(long val : hor) total += val;

        prefix = 0;
        for(int i = 0; i < m - 1; i++) {
            prefix += hor[i];
            if(prefix == total - prefix) return true;
        }

        return false;
    }
}
