class Solution {
    public int findMin(int[] nums) {

        int left = 0;
        int right = nums.length - 1;

        while(left < right) {

            int mid = left + (right - left)/2;

            if(nums[mid] > nums[right]) {

                // minimum on right side
                left = mid + 1;

            } else {

                // minimum at mid or left side
                right = mid;
            }
        }

        return nums[left];
    }
}
