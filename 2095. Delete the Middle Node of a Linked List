class Solution {
    public ListNode deleteMiddle(ListNode head) {

        if(head.next == null)
            return null;

        int count = 0;
        ListNode node = head;

        while(node != null)
        {
            count++;
            node = node.next;
        }

        int mid = count / 2;

        ListNode prev = head;

        for(int i = 0; i < mid - 1; i++)
        {
            prev = prev.next;
        }

        prev.next = prev.next.next;

        return head;
    }
}
