class Solution {
        public long totalWaviness(long num1, long num2) {
            long totalwaviness=0;


            for(long i = num1;i<num2+1;i++)
            {
                if(i<100)
                    continue;
                String num=Long.toString(i);
                char[] carr=num.toCharArray();
                for(long j=1;j<carr.length-1;j++)
                {
                    int left=Character.getNumericValue(carr[(int)j-1]);
                    int right=Character.getNumericValue(carr[(int)j+1]);
                    int val=Character.getNumericValue(carr[(int)j]);

                    if(val>left && val>right)
                        totalwaviness++;
                    if(val<left && val<right)
                        totalwaviness++;
                }
            }
            return totalwaviness;
        }
    }
