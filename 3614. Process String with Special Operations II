class Solution {
    public char processStr(String s, long k) {
        StringBuilder str=new StringBuilder();
        for(int i=0;i<s.length();i++)
        {
            char c=s.charAt(i);
            if(c=='*')
            {
                if(str.length() >0)
                    str.deleteCharAt(str.length()-1);
            }
            else if(c=='#')
            {
                str.append(str);
            }
            else if(c=='%')
            {
                str.reverse();
            }
            else if(c>='a' && c<='z')
            {
                str.append(c);
            }
            else{
                continue;
            }
        }
        String ans=str.toString();
        if(ans.length()>k)
        {
            return ans.charAt((int)(k));
        }
        else
        {
            return '.';
        }
    }
}
