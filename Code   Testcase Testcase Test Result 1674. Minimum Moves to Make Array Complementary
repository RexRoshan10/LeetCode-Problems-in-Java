class Solution {
    public int minMoves(int[] nums, int limit) {
        int n=nums.length;
        int dif[] =new int[limit*2+2];

        for(int i=0;i<n/2;i++)
        {
            int a=nums[i];
            int b=nums[n-i-1];

            int sum=a+b;

            int min=Math.min(a,b)+1;
            int max=Math.max(a,b)+limit;

            dif[2]+=2;

            dif[min]-=1;
            dif[max+1]+=1;

            dif[sum]-=1;
            dif[sum+1]+=1;
        }

        int ans=Integer.MAX_VALUE;
        int current=0;

        for(int i=2;i<2*limit;i++)
        {
            current+=dif[i];
            ans=Math.min(current,ans);
        }
        return ans;
    }
}
