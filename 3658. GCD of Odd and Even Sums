class Solution {
    public int gcdOfOddEvenSums(int n) {

        int oddsum = 0;
        int evensum = 0;

        int odd = 1;
        int even = 2;

        for(int i = 0; i < n; i++) {
            oddsum += odd;
            evensum += even;

            odd += 2;
            even += 2;
        }

        int gcd = 1;

        for(int i = 1; i <= Math.min(oddsum, evensum); i++) {
            if(oddsum % i == 0 && evensum % i == 0)
                gcd = i;
        }

        return gcd;
    }
}
