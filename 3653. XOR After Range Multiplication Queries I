class Solution {
    public int xorAfterQueries(int[] nums, int[][] queries) {
        int mod = 1000000007;

        for(int i = 0; i < queries.length; i++) {
            int[] row = queries[i];
            int idx = row[0];

            while(idx <= row[1]) {
                nums[idx] = (int)(((long)nums[idx] * row[3]) % mod);
                idx += row[2];
            }
        }

        int xor = 0;
        for(int val : nums) xor ^= val;

        return xor;
    }   
}
