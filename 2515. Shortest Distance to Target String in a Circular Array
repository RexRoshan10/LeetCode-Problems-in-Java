class Solution {
    public int closestTarget(String[] words, String target, int startIndex) {
        int n=words.length;
        int answer=0;

        int start=startIndex;
        int end=startIndex;
        int count=0;
        while(count<=n)
        {
            if(words[start].equals(target))
            {
                return answer;
            }
            else if(words[end].equals(target)){
                return answer;
            }
            else{
                answer++;
                count++;
                start--;
                if(start == -1)
                    start=n-1;
                end++;
                if(end == n)
                    end=0;
            }
        }
        return -1;
    }
}
