class Solution {
    public int[] pivotArray(int[] nums, int pivot) {
        int n=nums.length;
        int[] result=new int[n];
        int[] mid=new int[n];
        int[] lasta=new int[n];
        int midindex=0;
        int front=0;
        int last=0;
        for(int i=0;i<n;i++)
        {
            if(nums[i]<pivot)
            {
                result[front]=nums[i];
                front++;
            }
            else if(nums[i]>pivot)
            {
                lasta[last]=nums[i];
                last++;
            }
            else{
                mid[midindex]=nums[i];
                midindex++;
            }
        }
        for(int i=0;i<midindex;i++)
        {
            result[front]= mid[i];
            front++;
        }
        for(int i=0;i<last;i++)
        {
            result[front]=lasta[i];
            front++;
        }
        return result;
    }
}
